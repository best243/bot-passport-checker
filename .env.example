# ── Messenger Platform (Meta for Developers) ──────────────────
# Token de page généré dans l'app Meta (Messenger > Paramètres > Tokens d'accès à la page)
PAGE_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Chaîne secrète arbitraire, à saisir aussi dans la config du webhook Meta
VERIFY_TOKEN=opentravel-passport-verify

# ── URL publique du serveur déployé (Render) ──────────────────
# Utilisée pour générer les liens d'images et de partage. Sans valeur,
# le bot fonctionne mais sans envoi d'image ni bouton de partage.
BASE_URL=https://opentravel-passport.onrender.com

# ── API "Passport Index" (RapidAPI) ───────────────────────────
# Si absentes, le bot utilise des données de démonstration locales
# (data/mock-passports.json) pour rester fonctionnel.
RAPIDAPI_KEY=
RAPIDAPI_HOST=
# {code} sera remplacé par le code pays ISO2 (ex: CI, SN, FR...)
RAPIDAPI_PASSPORT_PATH=/passport/{code}

# ── Divers ─────────────────────────────────────────────────────
PORT=3000
